# ────────────────────────────────────────────
# Goobne Manager – 환경변수 목록
# 이 파일을 복사하여 .env.local 로 저장 후 값을 채워주세요.
# .env.local 은 .gitignore 에 포함되어 있어 커밋되지 않습니다.
# ────────────────────────────────────────────

# [필수] Supabase 프로젝트 URL
# Supabase 대시보드 → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co

# [필수] Supabase Anon (Public) Key
# Supabase 대시보드 → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
